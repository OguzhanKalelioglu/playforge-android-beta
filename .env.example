# ============================================
# Database
# ============================================
DB_PASSWORD=change-me-strong-password-here
DATABASE_URL=postgres://tester:change-me-strong-password-here@localhost:5432/testers
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT & Auth
# ============================================
JWT_SECRET=change-me-32-characters-minimum-length-secret-replace
NEXTAUTH_SECRET=change-me-32-characters-minimum-length-secret-replace

# ============================================
# Domain & Caddy
# ============================================
DOMAIN=testerscomm.net
ACME_EMAIL=admin@testerscomm.net

# ============================================
# Asynqmon (Queue monitoring UI)
# ============================================
ASYNQ_ADMIN_PASSWORD=change-me-admin-password

# ============================================
# Iyzico Payment
# ============================================
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzico.com

# ============================================
# Google API (opsiyonel, ilerde)
# ============================================
GOOGLE_SERVICE_ACCOUNT_JSON=

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.testerscomm.net
SMTP_PASSWORD=change-me

# ============================================
# Mini PC Orchestrator
# ============================================
ORCHESTRATOR_API_TOKEN=change-me-long-random-token-for-orchestrator
VPS_PUBLIC_IP=
MINIPC_PUBLIC_IP=

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
SENTRY_DSN=

# ============================================
# Emulator Farm
# ============================================
EMULATOR_MAX_INSTANCES=25
ADB_SERVER_PORT=5037
